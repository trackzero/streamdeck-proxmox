{
  "name": "com.trackzero.proxmox",
  "version": "1.0.0",
  "description": "Stream Deck plugin for monitoring and controlling Proxmox VMs and LXC containers",
  "main": "com.trackzero.proxmox.sdPlugin/bin/plugin.js",
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "watch": "rollup -c --bundleConfigAsCjs -w",
    "package": "streamdeck pack com.trackzero.proxmox.sdPlugin -f",
    "icons": "node scripts/create-icons.mjs"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.1",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^25.3.0",
    "rollup": "^4.9.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
